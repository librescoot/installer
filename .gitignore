.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Sensitive files
*.p12
*.pem
*.key

# Build artifacts
build/
*.exe
!assets/tools/*.exe

# Flasher binaries — fetched at build time by scripts/update-flasher.sh
# (see assets/tools/FLASHER_VERSION for the pinned tag)
/assets/tools/librescoot-flasher-linux-amd64
/assets/tools/librescoot-flasher-linux-arm64
/assets/tools/librescoot-flasher-linux-arm
/assets/tools/librescoot-flasher-darwin-amd64
/assets/tools/librescoot-flasher-darwin-arm64
/assets/tools/librescoot-flasher-windows-amd64.exe
/assets/tools/librescoot-flasher-windows-arm64.exe
